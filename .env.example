# =============================================================================
# maivn SDK environment variables
# =============================================================================
# These variables are read by the SDK when present. All are optional —
# values can also be set programmatically via Configuration or Agent kwargs.
# Copy this file to .env if using load_dotenv() in your application.
# =============================================================================

# --- Authentication ---
MAIVN_API_KEY=

# --- Server ---
MAIVN_TIMEOUT=                          # HTTP request timeout in seconds
MAIVN_MAX_RETRIES=                      # Maximum retry attempts
MAIVN_DEPLOYMENT_TIMEZONE=              # IANA timezone (e.g. America/New_York)

# --- Execution ---
MAIVN_EXECUTION_TIMEOUT=                # Default execution timeout (seconds)
MAIVN_PENDING_EVENT_TIMEOUT=            # Pending event timeout (seconds)
MAIVN_MAX_PARALLEL_TOOLS=               # Max parallel tool executions
MAIVN_ENABLE_BACKGROUND_EXECUTION=      # true/false — background vs inline
MAIVN_TOOL_EXECUTION_TIMEOUT=           # Per-tool timeout (seconds)
MAIVN_DEPENDENCY_WAIT_TIMEOUT=          # Dependency resolution timeout (seconds)
MAIVN_TOTAL_EXECUTION_TIMEOUT=          # Upper bound on entire session (seconds)
MAIVN_MAX_PROMPT_LENGTH=                # Max prompt length for tool naming
MAIVN_TOOL_NAME_HASH_MODULO=            # Modulo for tool name hash generation

# --- Logging ---
MAIVN_LOG_LEVEL=                        # DEBUG, INFO, WARNING, ERROR
MAIVN_LOG_FORMAT=                       # Custom log format string
MAIVN_ENABLE_TIMING_LOGS=              # true/false — enable timing logs

# --- Terminal Reporter ---
MAIVN_TERMINAL_STREAM_MODE=             # System tool stream mode (default: focus)
MAIVN_TERMINAL_STREAM_MAX_FPS=          # Max FPS for streaming panel (default: 10)

# --- Debug ---
MAIVN_DEBUG_KEEP_SYSTEM_TOOL_STREAM_PANEL=      # true/false — keep panel after completion
MAIVN_DEBUG_SYSTEM_TOOL_STREAM_DELIMITERS=      # true/false — show chunk delimiters
