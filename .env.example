# =============================================================================
# maivn (public Python SDK) — environment variables
# =============================================================================
# Copy to .env if you use load_dotenv() in your application; otherwise set
# these in your process environment.
#
# All variables are OPTIONAL. Each can also be set programmatically via
# Configuration() or Agent() kwargs — when both are present, the explicit
# kwarg wins.
#
# READ AT IMPORT — values applied automatically to every SDK process.
# OPT-IN — only consumed when the consumer calls
#   ConfigurationBuilder.from_environment(); the SDK does NOT call this for
#   you. Use these when you want a fully env-driven config without writing
#   any kwargs.
# =============================================================================


# =============================================================================
# READ AT IMPORT — terminal reporter (CLI display)
# =============================================================================

# System-tool stream mode. Default: focus.
# Other accepted values: full, off.
MAIVN_TERMINAL_STREAM_MODE=

# Max frames-per-second for the streaming panel. Default: 10.
MAIVN_TERMINAL_STREAM_MAX_FPS=

# Debug helpers — keep stream panel visible after completion / show
# raw chunk delimiters. Off in normal use.
MAIVN_DEBUG_KEEP_SYSTEM_TOOL_STREAM_PANEL=
MAIVN_DEBUG_SYSTEM_TOOL_STREAM_DELIMITERS=


# =============================================================================
# OPT-IN — used by ConfigurationBuilder.from_environment()
# =============================================================================
# These do nothing unless your application calls
# ConfigurationBuilder.from_environment() to assemble a Configuration.

# --- Authentication ---
MAIVN_API_KEY=

# --- Server / runtime ---
MAIVN_TIMEOUT=                          # HTTP request timeout (seconds)
MAIVN_MAX_RETRIES=                      # Maximum retry attempts
MAIVN_DEPLOYMENT_TIMEZONE=              # IANA timezone (e.g. America/New_York)

# --- Execution ---
MAIVN_EXECUTION_TIMEOUT=                # Default execution timeout (seconds)
MAIVN_PENDING_EVENT_TIMEOUT=            # Pending event timeout (seconds)
MAIVN_MAX_PARALLEL_TOOLS=               # Max parallel tool executions
MAIVN_ENABLE_BACKGROUND_EXECUTION=      # true/false — background vs inline
MAIVN_TOOL_EXECUTION_TIMEOUT=           # Per-tool timeout (seconds)
MAIVN_DEPENDENCY_WAIT_TIMEOUT=          # Dependency resolution timeout (seconds)
MAIVN_TOTAL_EXECUTION_TIMEOUT=          # Upper bound on entire session (seconds)
MAIVN_MAX_PROMPT_LENGTH=                # Max prompt length for tool naming
MAIVN_TOOL_NAME_HASH_MODULO=            # Modulo for tool name hash generation

# --- Logging ---
MAIVN_LOG_LEVEL=                        # DEBUG | INFO | WARNING | ERROR
MAIVN_LOG_FORMAT=                       # Custom log format string
MAIVN_ENABLE_TIMING_LOGS=               # true/false — enable timing logs
